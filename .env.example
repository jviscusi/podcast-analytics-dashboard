# Podcast Analytics Dashboard - Environment Variables
# Copy this file to .env and fill in your API credentials

# Server Configuration
PORT=3001
NODE_ENV=development

# Use mock data instead of real APIs (set to false when you have real credentials)
USE_MOCK_DATA=true

# RSS Feed URL (Riverside.fm hosting)
RSS_FEED_URL=https://api.riverside.fm/hosting/2ZZ2vMfH.rss

# Spotify for Podcasters API
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:3001/api/auth/spotify/callback
SPOTIFY_PODCAST_ID=your_spotify_podcast_id

# Apple Podcasts Connect API
APPLE_KEY_ID=your_apple_key_id
APPLE_ISSUER_ID=your_apple_issuer_id
APPLE_PRIVATE_KEY_PATH=./keys/apple_private_key.p8
APPLE_PODCAST_ID=your_apple_podcast_id

# YouTube Data API / YouTube Analytics API
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:3001/api/auth/youtube/callback
YOUTUBE_CHANNEL_ID=your_youtube_channel_id
YOUTUBE_PLAYLIST_ID=your_podcast_playlist_id
